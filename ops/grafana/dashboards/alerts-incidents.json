      "targets": [
        {
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  status_group AS \"Группа\",\n  status_key AS \"Ключ\",\n  status_value AS \"Статус\",\n  observed_at AS \"Наблюдалось\",\n  updated_at AS \"Обновлено\"\nFROM analytics_runtime_status\nORDER BY updated_at DESC\nLIMIT 20;",
          "refId": "A"
        }
      ],
      "title": "Статусы runtime",
      "type": "table"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "amonora-analytics"
      },
      "description": "",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "id": 7,
      "options": {
        "footer": {
          "show": false
        },
        "showHeader": true
      },
      "targets": [
        {
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  incident_class AS \"Класс\",\n  category AS \"Категория\",\n  severity AS \"Серьёзность\",\n  event_type AS \"Тип события\",\n  SUM(created_count)::bigint AS \"Создано\",\n  SUM(resolved_count)::bigint AS \"Решено\",\n  SUM(repeated_count)::bigint AS \"Повторов\"\nFROM analytics_hourly_ops_incidents\nWHERE bucket_hour >= NOW() - INTERVAL '24 hour'\nGROUP BY incident_class, category, severity, event_type\nORDER BY \"Создано\" DESC, \"Повторов\" DESC\nLIMIT 40;",
          "refId": "A"
        }
      ],
      "title": "Инциденты по классам",
      "type": "table"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "amonora-analytics"
      },
      "description": "",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 15
      },
      "id": 8,
      "options": {
        "footer": {
          "show": false
        },
        "showHeader": true
      },
      "targets": [
        {
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH daily_total AS (\n  SELECT bucket_date, COALESCE(SUM(users_count), 0)::bigint AS total_bot_start\n  FROM analytics_daily_stage_counts\n  WHERE bucket_date >= CURRENT_DATE - INTERVAL '29 day'\n    AND source_mode = 'first'\n    AND event_name = 'bot_start'\n  GROUP BY bucket_date\n)\nSELECT\n  integrity.bucket_date AS \"Дата\",\n  CASE integrity.issue_type\n    WHEN 'null_source_key' THEN 'NULL source_key'\n    WHEN 'empty_source_key' THEN 'Пустой source_key'\n    WHEN 'organic_bot' THEN 'Органика'\n    WHEN 'invalid_start_param' THEN 'Битый start_param'\n    ELSE 'События без атрибуции'\n  END AS \"Тип проблемы\",\n  integrity.issue_count AS \"Количество\",\n  ROUND(100.0 * (integrity.issue_count) / NULLIF((daily_total.total_bot_start), 0), 2) AS \"Доля, %\"\nFROM analytics_daily_attribution_integrity integrity\nLEFT JOIN daily_total ON daily_total.bucket_date = integrity.bucket_date\nWHERE integrity.bucket_date >= CURRENT_DATE - INTERVAL '29 day'\nORDER BY integrity.bucket_date DESC, \"Количество\" DESC;",
          "refId": "A"
        }
      ],
      "title": "Качество атрибуции по дням",
      "type": "table"
    },
