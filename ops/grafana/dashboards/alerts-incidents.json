          "rawQuery": true,
          "rawSql": "SELECT ROUND(COALESCE((detail_json::json ->> 'integrity_ratio')::numeric, 1.0) * 100, 2) AS value\nFROM analytics_runtime_status\nWHERE status_key = 'source_key_integrity'\nORDER BY updated_at DESC\nLIMIT 1;",
