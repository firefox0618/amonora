      "targets": [
        {
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  cohort_date AS \"Когорта\",\n  period_days AS \"День\",\n  cohort_size AS \"Размер\",\n  active_users AS \"Активны\",\n  renewed_users AS \"Продлили\",\n  expired_users AS \"Истекли\",\n  ROUND(100.0 * (active_users) / NULLIF((cohort_size), 0), 2) AS \"Активны, %\",\n  ROUND(100.0 * (renewed_users) / NULLIF((cohort_size), 0), 2) AS \"Продлили, %\"\nFROM analytics_cohort_retention\nWHERE cohort_type = '${cohort_type}'\nORDER BY cohort_date DESC, period_days ASC\nLIMIT 120;",
          "refId": "A"
        }
      ],
      "title": "Когортная таблица",
      "type": "table"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "amonora-analytics"
      },
      "description": "",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 12,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "id": 9,
      "options": {
        "footer": {
          "show": false
        },
        "showHeader": true
      },
      "targets": [
        {
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  period_days AS \"День\",\n  AVG(cohort_size)::numeric(12,2) AS \"Средний размер когорты\",\n  AVG(active_users)::numeric(12,2) AS \"Активны\",\n  AVG(renewed_users)::numeric(12,2) AS \"Продлили\",\n  AVG(expired_users)::numeric(12,2) AS \"Истекли\",\n  ROUND(AVG(100.0 * active_users / NULLIF(cohort_size, 0)), 2) AS \"Активны, %\",\n  ROUND(AVG(100.0 * renewed_users / NULLIF(cohort_size, 0)), 2) AS \"Продлили, %\"\nFROM analytics_cohort_retention\nWHERE cohort_type = '${cohort_type}'\nGROUP BY period_days\nORDER BY period_days;",
          "refId": "A"
        }
      ],
      "title": "Ядро удержания",
      "type": "table"
