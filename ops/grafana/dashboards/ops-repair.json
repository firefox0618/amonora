      "targets": [
        {
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT bucket_hour AS time, 'Открытые ремонты' AS metric, repair_needed_open_count::bigint AS value\nFROM analytics_hourly_ops_snapshots\nWHERE bucket_hour >= NOW() - INTERVAL '72 hour'\nUNION ALL\nSELECT bucket_hour AS time, 'Открытые инциденты' AS metric, unresolved_incident_count::bigint AS value\nFROM analytics_hourly_ops_snapshots\nWHERE bucket_hour >= NOW() - INTERVAL '72 hour'\nORDER BY time, metric;",
          "refId": "A"
        }
      ],
      "title": "Ремонты и инциденты по часам",
      "type": "timeseries"
    },
    {
      "datasource": {
