        },
        "showHeader": true
      },
      "targets": [
        {
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  incident_class AS \"Класс\",\n  category AS \"Категория\",\n  severity AS \"Серьёзность\",\n  event_type AS \"Тип события\",\n  SUM(created_count)::bigint AS \"Создано\",\n  SUM(resolved_count)::bigint AS \"Решено\",\n  SUM(repeated_count)::bigint AS \"Повторов\",\n  SUM(unique_entities_count)::bigint AS \"Сущностей\"\nFROM analytics_hourly_ops_incidents\nWHERE bucket_hour >= NOW() - INTERVAL '24 hour'\nGROUP BY incident_class, category, severity, event_type\nORDER BY \"Создано\" DESC, \"Повторов\" DESC\nLIMIT 40;",
          "refId": "A"
        }
      ],
      "title": "Инциденты по типам",
      "type": "table"
    },
