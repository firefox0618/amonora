          "show": false
        },
        "showHeader": true
      },
      "targets": [
        {
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  COALESCE(country_code, '—') AS \"Страна\",\n  SUM(config_issued_count)::bigint AS \"Ключи выданы\",\n  SUM(config_issue_failed_count)::bigint AS \"Ошибки выдачи\",\n  SUM(first_connection_success_count)::bigint AS \"Первые подключения\",\n  SUM(connection_failed_count)::bigint AS \"Ошибки подключения\",\n  ROUND(100.0 * (SUM(first_connection_success_count)) / NULLIF((SUM(config_issued_count)), 0), 2) AS \"Успех подключения, %\",\n  ROUND(AVG(NULLIF(avg_first_connection_lag_minutes, 0)), 2) AS \"Лаг, мин\"\nFROM analytics_daily_connection\nWHERE $__timeFilter(bucket_date::timestamp)\n  AND source_mode = '${source_mode}'\n  AND ('${source_key}' = '__all' OR source_key = '${source_key}')\nGROUP BY country_code\nORDER BY \"Первые подключения\" DESC, \"Ключи выданы\" DESC\nLIMIT 20;",
          "refId": "A"
        }
      ],
      "title": "Качество по странам",
      "type": "table"
    },
