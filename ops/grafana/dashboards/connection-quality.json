      "targets": [
        {
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH gap AS (\n  SELECT\n    COALESCE(SUM(CASE WHEN event_name IN ('subscription_activated','subscription_renewed') THEN users_count ELSE 0 END), 0)::bigint AS paid,\n    COALESCE(SUM(CASE WHEN event_name = 'first_connection_success' THEN users_count ELSE 0 END), 0)::bigint AS connected\n  FROM analytics_daily_stage_counts\n  WHERE $__timeFilter(bucket_date::timestamp)\n    AND source_mode = '${source_mode}'\n    AND ('${source_key}' = '__all' OR source_key = '${source_key}')\n    AND event_name IN ('subscription_activated','subscription_renewed','first_connection_success')\n)\nSELECT GREATEST(paid - connected, 0)::bigint AS value\nFROM gap;",
          "refId": "A"
        }
      ],
      "title": "Разрыв оплата→подключение",
      "type": "stat"
