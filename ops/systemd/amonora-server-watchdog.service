[Unit]
Description=Amonora server watchdog
After=network.target postgresql.service
Wants=network-online.target

[Service]
Type=oneshot
User=root
WorkingDirectory=/opt/amonora_bot
Environment=PYTHONPATH=/opt/amonora_bot
ExecStart=/opt/amonora_bot/venv/bin/python /opt/amonora_bot/ops/server_watchdog.py
